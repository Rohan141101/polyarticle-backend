{
  "expo": {
    "name": "PolyArticle",
    "slug": "flashfeed",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",

    "android": {
      "usesCleartextTraffic": true,
      "package": "com.anonymous.flashfeed",

      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },

      "permissions": []
    },

    "plugins": [
      "expo-secure-store",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2345974289373242~3123605011"
        }
      ]
    ],

    "assetBundlePatterns": [
      "**/*"
    ]
  }
}